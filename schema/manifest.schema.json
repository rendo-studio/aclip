{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aclip.dev/schema/manifest.schema.json",
  "title": "ACLIP Manifest",
  "type": "object",
  "required": ["protocol", "name", "version", "summary", "description", "command_groups", "commands", "credentials", "distribution"],
  "properties": {
    "protocol": { "const": "aclip/0.1" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "command_groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/pathSummary" }
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/pathSummary" }
    },
    "credentials": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/envCredential" },
          { "$ref": "#/$defs/fileCredential" }
        ]
      }
    },
    "distribution": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/standaloneBinaryDistribution" },
          { "$ref": "#/$defs/npmPackageDistribution" }
        ]
      }
    }
  },
  "$defs": {
    "pathSummary": {
      "type": "object",
      "required": ["path", "summary"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "standaloneBinaryDistribution": {
      "type": "object",
      "required": ["kind", "binary", "platform", "sha256"],
      "properties": {
        "kind": { "const": "standalone_binary" },
        "binary": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "minLength": 64, "maxLength": 64 }
      },
      "additionalProperties": false
    },
    "npmPackageDistribution": {
      "type": "object",
      "required": ["kind", "package", "version", "executable"],
      "properties": {
        "kind": { "const": "npm_package" },
        "package": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "executable": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "envCredential": {
      "type": "object",
      "required": ["name", "source", "required", "description", "envVar"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source": { "const": "env" },
        "required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 },
        "envVar": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "fileCredential": {
      "type": "object",
      "required": ["name", "source", "required", "description", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source": { "const": "file" },
        "required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
